{
  "expo": {
    "name": "parkgolf_community",
    "slug": "parkgolf_community",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-video",
      [
        "expo-image-picker",
        {
          "cameraPermission": "친구에게 보여줄 영상을 찍을 때 카메라가 필요해요.",
          "microphonePermission": "영상에 소리를 담을 때 마이크가 필요해요.",
          "photosPermission": "갤러리에서 영상을 고를 때 필요해요."
        }
      ]
    ]
  }
}
